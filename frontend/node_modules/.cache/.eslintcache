on/json\" },\n            withCredentials: true,\n            data: JSON.stringify({\n                email: \"paolo@milano.com\",\n                password: \"000000\",\n            }),\n        };\n        (async () => {\n            try {\n                const response = await axios(config);\n                setCounter(response.data)\n                console.log(\"response : \", response)\n                return response.data;\n            } catch (error) {\n                console.log(\"error : \", error)\n                // throw new Error(error);\n            }\n        })();\n    }, []);\n\n    return (\n        <>\n            <div className=\"container\">\n                <h1>home page</h1>\n                <div>\n                    <p>{counter}</p>\n                </div>\n                {/* <button onClick={handleSeed}>seed</button> */}\n            </div>\n        </>\n    );\n}\n",["80","81"],"/Users/boula/Documents/dev/github/projects/RESTful-APIs-with-Node.js-and-Express/frontend/src/ui/Header.js",[],[],"/Users/boula/Documents/dev/github/projects/RESTful-APIs-with-Node.js-and-Express/frontend/src/users/UsersLogin.js",[],[],"/Users/boula/Documents/dev/github/projects/RESTful-APIs-with-Node.js-and-Express/frontend/src/users/UsersLogout.js",[],[],"/Users/boula/Documents/dev/github/projects/RESTful-APIs-with-Node.js-and-Express/frontend/src/features/users/userSlice.js",[],[],"/Users/boula/Documents/dev/github/projects/RESTful-APIs-with-Node.js-and-Express/frontend/src/auth/firebaseInit.js",[],[],["82","83"],"/Users/boula/Documents/dev/github/projects/RESTful-APIs-with-Node.js-and-Express/frontend/src/auth/useAuthentication.js",[],[],{"ruleId":"84","replacedBy":"85"},{"ruleId":"86","replacedBy":"87"},{"ruleId":"84","replacedBy":"88"},{"ruleId":"86","replacedBy":"89"},{"ruleId":"84","replacedBy":"90"},{"ruleId":"86","replacedBy":"91"},{"ruleId":"92","severity":1,"message":"93","line":1,"column":16,"nodeType":"94","messageId":"95","endLine":1,"endColumn":